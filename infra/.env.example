# Copy this file to .env in the same directory and fill in real values.
# .env is gitignored — never commit actual secrets.

# --- PostgreSQL ---
DB_NAME=documind
DB_USERNAME=documind
DB_PASSWORD=change-me

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=documind-minio
MINIO_ROOT_PASSWORD=change-me

# --- Auth ---
# Must be a long, random, base64-safe string. Rotate by issuing new tokens
# signed with a new key; existing tokens signed with the old key will fail
# validation once rotated (acceptable, since access tokens are short-lived).
JWT_SIGNING_KEY=change-me-to-a-long-random-secret

# --- LLM / embedding providers ---
ANTHROPIC_API_KEY=change-me
VOYAGE_API_KEY=change-me
